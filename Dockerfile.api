FROM mambaorg/micromamba:1.5.8

WORKDIR /app

COPY environment.api.docker.yml /tmp/environment.yml
RUN micromamba install -y -n base -f /tmp/environment.yml \
 && micromamba clean -a -y

COPY . .

EXPOSE 8000
CMD ["micromamba","run","-n","base","uvicorn","src.api.app:app","--host","0.0.0.0","--port","8000"]